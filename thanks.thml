<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,user-scalable=no">
<title>友だち追加ありがとうございます</title>

<!-- TikTok Pixel Code Start -->
